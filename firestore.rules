rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if true;
    }

    match /battles/{battleId} {
      allow read, write: if true;
    }

    match /joinedBattles/{joinedId} {
      allow read, write: if true;
    }

    match /transactions/{txId} {
      allow read, write: if true;
    }

    match /supportMessages/{msgId} {
      allow read, write: if true;
    }
  }
}